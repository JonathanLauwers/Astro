---
import type { HTMLAttributes } from 'astro/types';
import { cva, type VariantProps } from 'class-variance-authority';

import { cn } from '@/lib/utils';

interface Props extends HTMLAttributes<'header'>, VariantProps<typeof variants> {}

const { class: className, ...props } = Astro.props;
---

<header
  class={cn(
    'bg-transparent w-full top-0 z-50 mx-auto flex items-center justify-between gap-8 border-b border-transparent py-2',
    className
  )}
  data-slot="header"
  {...props}
>
  <slot />
</header>
