---
import Text from '../Text.astro';
import ContentfulImage from './ContentfulImage.astro';
import Image from './Image.astro';

interface HeroFields {
  media?: any;
  title?: string;
}

interface Props {
  class?: string;
  data?: {
    fields?: HeroFields;
  };
}

const { class: className = '', data } = Astro.props;
if (!data?.fields) return null;

const { media, title } = data.fields;
const darken = !!title;
---

<div class:list={['relative mx-[calc((100vw-100%)/-2)] flex items-center', className]}>
  <div class:list={['w-full', darken && 'brightness-[.7]']}>
    <Image data={media} width={1750} priority />
  </div>

  {
    title && (
      <Text
        type="h1"
        class="absolute top-1/3 left-1/2 w-3/4 -translate-x-1/2 -translate-y-1/2 text-center text-white"
        style="text-shadow: rgba(203,124,73,0.4) 5px 5px, rgba(203,124,73,0.3) 10px 10px, rgba(203,124,73,0.2) 15px 15px, rgba(203,124,73,0.1) 20px 20px, rgba(203,124,73,0.05) 25px 25px;"
      >
        {title}
      </Text>
    )
  }
</div>
