---
import { Icon } from 'astro-icon/components';
import RichTextPlain from './RichTextPlain.astro';
import Text from '../Text.astro';
import { Button } from '../ui/button';

interface AuthorFields {
  company?: string;
  role?: string;
  name?: string;
}

interface ContentRichTextFields {
  copy?: string; // if your copy is HTML, this can be rendered with set:html
}

interface TestimonialFields {
  author?: { fields?: AuthorFields };
  copy?: { fields?: ContentRichTextFields };
}

interface Props {
  data?: { fields?: TestimonialFields };
  class?: string;
}

const { data, class: className = '' } = Astro.props;

if (!data?.fields) return null;

const { author, copy: rteCopy } = data.fields;
const { copy = '' } = (rteCopy?.fields || {}) as ContentRichTextFields;
const { company = '', role = '', name = '' } = (author?.fields || {}) as AuthorFields;
---

<div
  class:list={[
    'mx-auto flex w-full max-w-[1200px] flex-col gap-3 pt-20 pb-10 md:px-24 md:pt-10',
    className,
  ]}
>
  <div class="relative">
    <Icon
      name="carbon:quotes"
      class="absolute bottom-full left-0 size-24 text-orange-500 md:-top-10 md:right-full md:bottom-auto md:left-auto"
    />

    <RichTextPlain
      copy={copy}
      class="text-center text-xl leading-relaxed font-light italic md:text-3xl"
    />
  </div>

  <Text tag="p" class="self-end text-xl font-semibold">{name}</Text>
  <Text tag="p" class="self-end text-sm text-slate-700">{role} @ {company}</Text>
</div>
